{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main PDU data automation window",
  "windows": ["main"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:allow-open",
    "updater:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "C:/PDU500/**"
        },
        {
          "path": "$HOME/**"
        }
      ]
    }
  ]
}
