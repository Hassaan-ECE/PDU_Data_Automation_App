{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pdu-data-automation.local/schemas/report-layout.schema.json",
  "title": "PDU Report Layout Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "display_name",
    "templates",
    "workbooks",
    "task_groups"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string"
    },
    "templates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_template_root",
        "main_report_template",
        "print_report_template"
      ],
      "properties": {
        "default_template_root": {
          "type": "string",
          "minLength": 1
        },
        "main_report_template": {
          "type": "string",
          "minLength": 1
        },
        "print_report_template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workbooks": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/workbook"
      }
    },
    "serial_number": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "folder_pattern"
      ],
      "properties": {
        "folder_pattern": {
          "type": "string",
          "minLength": 1
        },
        "metadata_files": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "task_groups": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/task_group"
      }
    }
  },
  "definitions": {
    "workbook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "file_pattern"
      ],
      "properties": {
        "file_pattern": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "task_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "tasks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "tasks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/task"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "step",
        "csv_pattern"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "step": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "detection_steps": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "processor": {
          "type": "string",
          "minLength": 1
        },
        "csv_pattern": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mappings": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/mapping"
          }
        }
      }
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "target"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/definitions/mapping_source"
        },
        "transform": {
          "$ref": "#/definitions/transform"
        },
        "target": {
          "$ref": "#/definitions/mapping_target"
        }
      }
    },
    "mapping_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "column",
        "row"
      ],
      "properties": {
        "column": {
          "type": "string",
          "minLength": 1
        },
        "row": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scale_by": {
          "type": "number"
        },
        "round": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "mapping_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workbook",
        "sheet",
        "cell"
      ],
      "properties": {
        "workbook": {
          "type": "string",
          "minLength": 1
        },
        "sheet": {
          "type": "string",
          "minLength": 1
        },
        "cell": {
          "type": "string",
          "pattern": "^[A-Z]{1,3}[1-9][0-9]*$"
        },
        "number_format": {
          "type": "string"
        }
      }
    }
  }
}
