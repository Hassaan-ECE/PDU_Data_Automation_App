{
  "name": "pdu-data-automation-app",
  "private": true,
  "version": "0.2.13",
  "packageManager": "bun@1.3.13",
  "description": "PDU data automation desktop app built with Tauri, React, TypeScript, and Rust.",
  "author": "Syed Hassaan Shah",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite --config frontend/vite.config.ts",
    "dev:frontend": "bun --bun vite --config frontend/vite.config.ts",
    "desktop": "cargo tauri dev --config backend/tauri.conf.json",
    "dev:desktop": "cargo tauri dev --config backend/tauri.conf.json",
    "start:desktop": "cargo tauri dev --config backend/tauri.conf.json",
    "build": "bun --bun tsc -b && bun --bun vite build --config frontend/vite.config.ts",
    "build:frontend": "bun --bun tsc -b && bun --bun vite build --config frontend/vite.config.ts",
    "build:desktop": "cargo tauri build --config backend/tauri.conf.json --bundles nsis",
    "lint": "eslint .",
    "preview": "bun --bun vite preview --config frontend/vite.config.ts",
    "tauri": "cargo tauri",
    "test": "bun --bun vitest run --config frontend/vite.config.ts",
    "check:versions": "node scripts/release/check-version-consistency.mjs",
    "validate": "node scripts/validate-local.mjs",
    "validate:report-layouts": "node scripts/fixtures/validate-report-layout-schema.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^6.15.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
